# Публічні — потрапляють у клієнтський бандл, використовуються лише для
# Supabase Auth (сесія адміна). RLS на таблицях лідів deny-all, тож цей
# ключ не дає прямого доступу до заявок.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Серверний, секретний — НІКОЛИ не префіксувати NEXT_PUBLIC_. Обходить RLS,
# використовується лише в Server Actions і admin server components.
SUPABASE_SERVICE_ROLE_KEY=
